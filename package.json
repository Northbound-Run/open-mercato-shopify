{
  "name": "@northbound-run/sync-shopify",
  "version": "0.4.1",
  "description": "Shopify → Open Mercato Data Sync adapter: syncs products, variants, prices, collections, customers and orders from a Shopify store into Open Mercato's native catalog, customer and sales entities.",
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "author": "Northbound",
  "homepage": "https://github.com/Northbound-Run/open-mercato-shopify",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Northbound-Run/open-mercato-shopify.git"
  },
  "keywords": [
    "open-mercato",
    "open-mercato-module",
    "shopify",
    "data-sync",
    "ecommerce"
  ],
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "node build.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "probe": "node build.mjs && node scripts/probe.mjs",
    "prepublishOnly": "yarn build"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./*.ts": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./*.tsx": {
      "types": "./src/*.tsx",
      "default": "./dist/*.js"
    },
    "./*.json": "./src/*.json",
    "./*": {
      "types": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    },
    "./*/*.json": "./src/*/*.json",
    "./*/*": {
      "types": [
        "./src/*/*.ts",
        "./src/*/*.tsx"
      ],
      "default": "./dist/*/*.js"
    },
    "./*/*/*.json": "./src/*/*/*.json",
    "./*/*/*": {
      "types": [
        "./src/*/*/*.ts",
        "./src/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*/*.json": "./src/*/*/*/*.json",
    "./*/*/*/*": {
      "types": [
        "./src/*/*/*/*.ts",
        "./src/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*.js"
    },
    "./*/*/*/*/*.json": "./src/*/*/*/*/*.json",
    "./*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*.ts",
        "./src/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*.json": "./src/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*.js"
    }
  },
  "dependencies": {
    "@open-mercato/core": "^0.6.6",
    "@open-mercato/ui": "^0.6.6",
    "@shopify/admin-api-client": "^1.1.2"
  },
  "peerDependencies": {
    "@mikro-orm/postgresql": "^7.0.14",
    "@open-mercato/shared": ">=0.6.0 <0.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@mikro-orm/core": "^7.0.14",
    "@mikro-orm/decorators": "^7.0.14",
    "@mikro-orm/migrations": "^7.0.14",
    "@mikro-orm/postgresql": "^7.0.14",
    "@open-mercato/shared": "^0.6.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "awilix": "^12.1.1",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
