# Shopify connection, for `yarn probe` and `mercato sync_shopify configure-from-env`.
#
#   cp .env.example .env      # .env is gitignored
#   node --env-file=.env scripts/probe.mjs
#
# In a deployed Open Mercato app the connection is resolved env-first at runtime: these vars are the
# default, and a credential entered in the admin UI (stored encrypted) overrides them per tenant.

# Permanent .myshopify.com domain (Settings -> Domains), not a custom storefront domain.
OM_INTEGRATION_SHOPIFY_SHOP_DOMAIN=mystore.myshopify.com

# Dev Dashboard -> your app -> Settings. The secret is the value beginning shpss_.
OM_INTEGRATION_SHOPIFY_CLIENT_ID=
OM_INTEGRATION_SHOPIFY_CLIENT_SECRET=

# Optional. Defaults to the version pinned in lib/constants.ts.
# OM_INTEGRATION_SHOPIFY_API_VERSION=2026-07

# ── Optional: data-sync bootstrap ───────────────────────────────────────────────────────────────
# When the shop domain above is set, tenant bootstrap (setup.ts) ENABLES ALL FIVE SYNCS BY DEFAULT —
# the deployment already knows the credentials, so no admin toggling is needed. Enabling is
# non-destructive: an integration an operator has already toggled in the admin UI is left alone.
# Set this to opt out (`none`) or to a subset. Values: products, collections, customers, orders,
# inventory, or `all` / `none`.
# OM_INTEGRATION_SHOPIFY_ENABLE_ENTITIES=all

# Optional. When set — and @open-mercato/scheduler is installed — seed a recurring incremental import
# schedule for each enabled DELTA sync (products, collections, customers, orders) using this cron.
# Ignored without the scheduler module. Existing schedules are never overwritten.
# OM_INTEGRATION_SHOPIFY_SYNC_CRON=0 * * * *

# Optional. Separate cadence for the inventory snapshot, which captures one row per variant/location
# per day — so schedule it daily, not hourly. Without this, inventory is enabled but not auto-scheduled.
# OM_INTEGRATION_SHOPIFY_SYNC_CRON_INVENTORY=0 2 * * *

# Optional timezone for the seeded schedules. Defaults to UTC.
# OM_INTEGRATION_SHOPIFY_SYNC_TIMEZONE=UTC
